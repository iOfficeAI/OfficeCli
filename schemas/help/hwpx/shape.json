{
  "$schema": "../_schema.json",
  "format": "hwpx",
  "element": "shape",
  "parent": "paragraph|section",
  "operations": { "add": true, "set": true, "get": true, "query": true, "remove": true },
  "paths": { "positional": ["/section[N]/p[N]/shape[N]"] },
  "properties": {
    "geometry": { "type": "string", "add": true, "set": true, "get": true, "query": true, "examples": ["--prop geometry=rect"], "enforcement": "report" },
    "fill": { "type": "color", "add": true, "set": true, "get": true, "query": true, "examples": ["--prop fill=#00AAFF"], "enforcement": "report" }
  }
}
