{
  "$schema": "../_schema.json",
  "format": "hwpx",
  "element": "picture",
  "parent": "paragraph|section",
  "operations": { "add": true, "set": true, "get": true, "query": true, "remove": true },
  "paths": { "positional": ["/section[N]/p[N]/pic[N]"] },
  "properties": {
    "src": { "type": "string", "add": true, "set": true, "get": true, "query": true, "examples": ["--prop src=photo.png"], "enforcement": "strict" },
    "alt": { "type": "string", "add": true, "set": true, "get": true, "query": true, "examples": ["--prop alt=사진"], "enforcement": "report" },
    "bindata": { "type": "string", "get": true, "query": true, "description": "Referenced BinData entry.", "enforcement": "report" }
  }
}
