{
  "$schema": "../_schema.json",
  "format": "hwpx",
  "element": "validate",
  "container": true,
  "operations": { "add": false, "set": false, "get": true, "query": true, "remove": false },
  "paths": { "positional": ["/validate"] },
  "note": "Planned HWPX package and semantic validation entry. Must include ZIP, XML, manifest/header, BinData, and reference checks.",
  "properties": {
    "strict": { "type": "bool", "get": true, "query": true, "examples": ["--strict"], "enforcement": "report" },
    "ok": { "type": "bool", "get": true, "query": true, "enforcement": "strict" }
  }
}
