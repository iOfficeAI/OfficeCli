{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "officecli/interfaces/diff-result/v1",
  "title": "OfficeCLI Diff Result",
  "type": "object",
  "required": ["format", "before", "after", "changes"],
  "properties": {
    "format": { "type": "string" },
    "before": { "type": "string" },
    "after": { "type": "string" },
    "changes": { "type": "array" },
    "summary": { "type": "object" },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
